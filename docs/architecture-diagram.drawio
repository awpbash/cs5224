        <mxCell id="note" value="&lt;b&gt;Estimated Cost: ~$5–12/month&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px;color:#666;'&gt;No NAT Gateway ($0)&lt;br&gt;Fargate ~$0.05/job&lt;br&gt;Bedrock ~$0.001/call&lt;br&gt;Rest: AWS Free Tier&lt;/font&gt;" style="shape=note;size=14;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FDD835;fontSize=11;fontStyle=0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
